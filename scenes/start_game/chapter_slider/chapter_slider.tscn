vertical_alignment = 1

; Chapter description text.
[node name="ChapterDescription" type="Label" parent="."]
layout_mode = 1
anchors_preset = -1
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 90.0
offset_top = -688.0
offset_right = -90.0
offset_bottom = -517.0
