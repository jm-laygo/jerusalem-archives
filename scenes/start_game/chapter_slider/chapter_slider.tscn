; Root component used to browse and select a chapter.
[node name="ChapterSlider" type="Control"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_chapter_slider_script")

; Main chapter illustration shown behind the title and description.
[node name="ChapterIllustration" type="TextureRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
texture = ExtResource("3_chapter_one_illustration")
stretch_mode = 6

; Header image shown at the top of the chapter slider.
[node name="ChapterHeader" type="TextureRect" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 171.0
grow_horizontal = 2
texture = ExtResource("2_chapter_one_header")
expand_mode = 1
stretch_mode = 6

; Chapter title text.
[node name="ChapterTitle" type="Label" parent="."]
layout_mode = 1
anchors_preset = -1
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 60.0
offset_top = -920.0
offset_right = -60.0
offset_bottom = -794.0
grow_horizontal = 2
theme_override_colors/font_color = Color(0.92, 0.86, 0.76, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 0.9)
